#from langchain_community.chat_models import ChatOpenAI
from langchain_openai import ChatOpenAI
from langchain.schema import SystemMessage, HumanMessage
import os
from dotenv import load_dotenv

load_dotenv()

llm = ChatOpenAI(openai_api_key=os.getenv("OPENAI_API_KEY"), temperature=0.8)

def generate_quest_from_location(lat, lon):
    prompt = f"""
You are an adventure generator. A user is located at latitude {lat} and longitude {lon}. 
Suggest one fun and creative **outdoor activity** or quest they could do around them. 
Make it 2-3 sentences long and sound exciting and positive. Avoid repeating suggestions.
"""

    messages = [
        SystemMessage(content="You are a helpful assistant that gives fun, real-world quests."),
        HumanMessage(content=prompt)
    ]
    
    response = llm(messages)
    return response.content
